# v3/.npmrc — workspace linking
#
# Pnpm 8+ defaults to `link-workspace-packages=false`, which means pnpm only
# resolves a dependency from the local workspace if it uses `workspace:*` or
# `workspace:<range>` protocol. With literal versions (which our publish path
# requires — `npm publish` can't rewrite `workspace:*`), pnpm would otherwise
# try to resolve every intra-workspace `@claude-flow/*` dep from the public
# registry, where these `-patch.N` versions don't exist.
#
# Enabling these two settings tells pnpm to PREFER local workspace packages
# when the local version matches the requested version — keeping the publish-
# path literal versions usable for local-dev `pnpm install --lockfile-only`
# AND `pnpm install`. No package.json changes needed.
#
# Background: https://pnpm.io/npmrc#link-workspace-packages
# Tracking: ADR-0257 deferred-item resolution (agent-browser lockfile pick)
link-workspace-packages=true
prefer-workspace-packages=true
